      "expectedBusinessOutcome": "SUCCESS",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-complaint-01",
      "category": "Complaints",
      "conversation": [
        { "role": "user", "content": "This app is terrible, my food is cold." }
      ],
      "expectedIntent": "complain",
      "expectedTool": "none",
      "expectedBusinessOutcome": "INFO",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-smalltalk-01",
      "category": "Small Talk",
      "conversation": [
        { "role": "user", "content": "How is your day going, robot?" }
      ],
      "expectedIntent": "smalltalk",
