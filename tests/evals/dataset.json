{
  "datasetVersion": "1.0.0",
  "createdAt": "2026-07-20T00:00:00Z",
  "description": "Production Gate 3 Evaluation Baseline Dataset",
  "scenarios": [
    {
      "id": "eval-ordering-01",
      "category": "Ordering",
      "conversation": [
        { "role": "user", "content": "I would like to order one classic burger please." }
      ],
      "expectedIntent": "add_to_cart",
      "expectedTool": "add_to_cart",
      "expectedToolArgs": { "dishId": "dish-burger", "quantity": 1 },
      "expectedBusinessOutcome": "SUCCESS",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-recommendations-01",
      "category": "Recommendations",
      "conversation": [
        { "role": "user", "content": "What do you recommend for someone who likes spicy food?" }
      ],
      "expectedIntent": "recommend",
      "expectedTool": "none",
      "expectedBusinessOutcome": "INFO",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-dietary-01",
      "category": "Dietary Restrictions",
      "conversation": [
        { "role": "user", "content": "Do you have any vegan options?" }
      ],
      "expectedIntent": "inquire",
      "expectedTool": "none",
      "expectedBusinessOutcome": "INFO",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-allergies-01",
      "category": "Allergies",
      "conversation": [
        { "role": "user", "content": "I'm allergic to peanuts. Is the burger safe?" }
      ],
      "expectedIntent": "inquire",
      "expectedTool": "none",
      "expectedBusinessOutcome": "INFO",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-out-of-stock-01",
      "category": "Out-of-Stock",
      "conversation": [
        { "role": "user", "content": "Can I have the special seasonal out-of-stock dish?" }
      ],
      "expectedIntent": "add_to_cart",
      "expectedTool": "add_to_cart",
      "expectedToolArgs": { "dishId": "dish-out-of-stock", "quantity": 1 },
      "expectedBusinessOutcome": "FAILURE",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-order-mod-01",
      "category": "Order Modification",
      "conversation": [
        { "role": "user", "content": "Actually, make that two burgers instead of one." }
      ],
      "expectedIntent": "add_to_cart",
      "expectedTool": "add_to_cart",
      "expectedToolArgs": { "dishId": "dish-burger", "quantity": 1 },
      "expectedBusinessOutcome": "SUCCESS",
      "expectedPolicy": "ALLOWED"
    },
    {
      "id": "eval-checkout-01",
      "category": "Checkout",
      "conversation": [
        { "role": "user", "content": "I'm done, I'd like to pay now." }
      ],
